{
  "num_workers": 14,
  "worktree_prefix": "ozon-w",
  "worktree_placement": "inside",
  "branch": "main",
  "auto_merge_worktrees": true,
  "create_bead_on_merge_conflict": true,
  "merge_slot": true,
  "auto_retry_merge_on_conflict_close": true,
  "worker_timeout_secs": 1200,
  "max_worker_retries": 2,
  "auto_unblock_in_progress": true,
  "auto_unblock_interval_secs": 60,
  "auto_unblock_max_items": 10,
  "poll_interval_secs": 0.5,
  "bd_sync_interval_secs": 30,
  "worker_backend": "qwen",
  "claude_cmd": "qwen",
  "claude_model": "ollama/qwen2.5-coder:7b",
  "model": "ollama/qwen2.5-coder:7b",
  "aider_cmd": "aider",
  "repo_root": "."
}
