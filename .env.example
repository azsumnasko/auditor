# Copy to .env and fill in your values. Do not commit .env.

# --- Jira Configuration (required) ---
JIRA_BASE_URL=https://company.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_TOKEN=your-jira-api-token
JIRA_PROJECT_KEYS=PROJ1,PROJ2

# --- Git Configuration (optional) ---
GIT_PROVIDER=github
# GIT_BASE_URL=https://api.github.com
GIT_TOKEN=ghp_your-github-pat
GIT_ORG=your-org
GIT_REPOS=*
GIT_LOOKBACK_DAYS=180

# --- Repo Configuration (optional, JSON array) ---
# Defines per-repo branch, Octopus mapping, and exclude patterns.
# Managed via the Config UI. Also auto-derives the Octopus repo map.
# REPO_CONFIG=[{"repo":"Gateway","branch":"stable","octopus":"Gateway"},{"repo":"FrontendV2","branch":"main","octopus":"","exclude_regex":"^(chore|ci|build)\\(release\\)"}]

# --- CI/CD Configuration (optional) ---
CICD_PROVIDER=github_actions
# CICD_PROVIDER=jenkins
# CICD_PROVIDER=none
# CICD_BASE_URL=https://jenkins.company.com
# CICD_DEPLOY_WORKFLOW=deploy.yml
CICD_LOOKBACK_DAYS=90

# --- Octopus Deploy Configuration (optional) ---
# OCTOPUS_SERVER_URL=https://company.octopus.app
# OCTOPUS_API_KEY=API-your-octopus-key
# OCTOPUS_ENVIRONMENT=Ontario
# OCTOPUS_SPACE_ID=Spaces-1
# OCTOPUS_REPO_MAP={"TransactionHistory": "TH", "PAM": "PAM"}
# OCTOPUS_LOOKBACK_DAYS=180

# --- Code Analysis (optional, for local repos) ---
# CODE_REPOS_PATH=/path/to/repo1,/path/to/repo2
# CODE_SONAR_URL=https://sonar.company.com
# CODE_SONAR_TOKEN=your-sonar-token
# CODE_SONAR_PROJECTS=project1,project2

# --- Docker Compose ---
# CODE_REPOS_PATH=/path/to/local/repos  (mounted as /repos in worker container)
# SESSION_SECRET=change-me-in-production

# --- Output ---
# OUTPUT_DIR=.  (defaults to script directory)
